  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "devDependencies": {
    "@karakeep/tsconfig": "workspace:^0.1.0",
    "typescript": "^6.0.0"
  }
}
