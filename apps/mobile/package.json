{
  "name": "@karakeep/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .expo .turbo node_modules",
    "clean:prebuild": "APP_VARIANT=development expo prebuild --no-install --clean",
    "expo": "expo",
    "start": "expo start",
    "android": "APP_VARIANT=development expo run:android",
    "android:preview": "SENTRY_DISABLE_AUTO_UPLOAD=true APP_VARIANT=development pnpm run android --variant release",
    "android:release": "SENTRY_DISABLE_AUTO_UPLOAD=true pnpm run android --variant release",
    "ios": "APP_VARIANT=development expo run:ios",
    "ios:preview": "SENTRY_DISABLE_AUTO_UPLOAD=true APP_VARIANT=development pnpm run ios --configuration Release",
    "ios:release": "SENTRY_DISABLE_AUTO_UPLOAD=true pnpm run ios --configuration Release",
    "web": "expo start --web",
    "format": "oxfmt --ignore-path=../../.gitignore --ignore-path=./.gitignore --check .",
    "format:fix": "oxfmt --ignore-path=../../.gitignore --ignore-path=./.gitignore .",
    "lint": "oxlint --ignore-path=../../.gitignore .",
    "lint:fix": "oxlint --ignore-path=../../.gitignore . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.0",
    "@expo/vector-icons": "^15.0.3",
    "@karakeep/shared": "workspace:^0.1.0",
