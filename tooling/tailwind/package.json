{
  "name": "@karakeep/tailwind-config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./native": "./native.ts",
    "./web": "./web.ts",
    "./globals.css": "./globals.css"
  },
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "format": "oxfmt --ignore-path=../../.gitignore --check .",
    "format:fix": "oxfmt --ignore-path=../../.gitignore .",
    "lint": "oxlint --ignore-path=../../.gitignore .",
    "lint:fix": "oxlint --ignore-path=../../.gitignore . --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "nativewind": "^4.2.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@karakeep/tsconfig": "workspace:^0.1.0",
    "typescript": "^6.0.0"
  }
}
