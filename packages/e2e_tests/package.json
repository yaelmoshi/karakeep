{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@karakeep/e2e_tests",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --ignore-path=../../.gitignore --ignore-path=./.gitignore --check .",
    "format:fix": "oxfmt --ignore-path=../../.gitignore --ignore-path=./.gitignore .",
    "lint": "oxlint --ignore-path=../../.gitignore --ignore-pattern='setup/docker-logs/**' .",
    "lint:fix": "oxlint --ignore-path=../../.gitignore --ignore-pattern='setup/docker-logs/**' . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:no-build": "E2E_TEST_NO_BUILD=1 vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@karakeep/sdk": "workspace:*",
    "@karakeep/shared": "workspace:^0.1.0",
    "@karakeep/trpc": "workspace:^0.1.0",
    "@trpc/client": "^11.17.0",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@karakeep/tsconfig": "workspace:^0.1.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.0"
  }
}
