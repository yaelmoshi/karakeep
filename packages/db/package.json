{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@karakeep/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "migrate": "tsx migrate.ts",
