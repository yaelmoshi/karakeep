{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@karakeep/plugins",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "exports": {
    "./queue-liteque": "./queue-liteque/index.ts",
    "./queue-postgres": "./queue-postgres/index.ts",
    "./queue-restate": "./queue-restate/index.ts",
    "./ratelimit-memory": "./ratelimit-memory/index.ts",
    "./ratelimit-redis": "./ratelimit-redis/index.ts",
    "./search-meilisearch": "./search-meilisearch/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --ignore-path=../../.gitignore --check .",
    "format:fix": "oxfmt --ignore-path=../../.gitignore .",
    "lint": "oxlint --ignore-path=../../.gitignore .",
    "lint:fix": "oxlint --ignore-path=../../.gitignore . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@karakeep/shared": "workspace:*",
    "@restatedev/restate-sdk": "^1.14.3",
    "@restatedev/restate-sdk-clients": "^1.14.3",
    "async-mutex": "^0.5.0",
    "meilisearch": "^0.58.0",
    "postgres": "^3.4.9",
    "redis": "^6.0.0"
  },
  "optionalDependencies": {
    "liteque": "^0.8.0"
  },
  "devDependencies": {
    "@karakeep/tsconfig": "workspace:^0.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.0"
  }
}
