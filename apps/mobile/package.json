    "@sentry/react-native": "^8.3.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.0.0",
    "expo": "~55.0.0",
    "expo-blur": "~55.0.8",
