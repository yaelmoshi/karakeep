{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@karakeep/landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:portless": "portless run --name karakeep-landing --lan astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "oxlint --ignore-path=../../.gitignore .",
    "lint:fix": "oxlint --ignore-path=../../.gitignore . --fix",
    "format": "oxfmt --ignore-path=../../.gitignore --check .",
    "format:fix": "oxfmt --ignore-path=../../.gitignore .",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^5.0.5",
    "@radix-ui/react-slot": "^1.2.4",
    "astro": "6.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.35.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@karakeep/tailwind-config": "workspace:^0.1.0",
    "@karakeep/tsconfig": "workspace:^0.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "portless": "^0.14.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^4.0.0",
    "vite-plugin-svgr": "^5.0.0"
  }
}
